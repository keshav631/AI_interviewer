            },
            "url": {
              "raw": "{{baseUrl}}/api/sessions/{{sessionId}}/submit-answer",
              "host": ["{{baseUrl}}"],
              "path": ["api", "sessions", "{{sessionId}}", "submit-answer"]
            },
            "description": "Submit either code, audio, or both. For audio, attach a file to the audioFile field."
          }
        }
